@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">
        <i class="fas fa-tasks text-primary me-3"></i>
        Welcome to Task Manager
    </h1>
    <p class="lead">Organize your tasks efficiently with our web-based task management system.</p>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <i class="fas fa-plus-circle text-success fa-3x mb-3"></i>
                    <h5 class="card-title">Add Tasks</h5>
                    <p class="card-text">Quickly add new tasks with descriptions to keep track of your to-do items.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <i class="fas fa-check-circle text-primary fa-3x mb-3"></i>
                    <h5 class="card-title">Complete Tasks</h5>
                    <p class="card-text">Mark tasks as complete when finished and track your completion dates.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <i class="fas fa-trash text-danger fa-3x mb-3"></i>
                    <h5 class="card-title">Delete Tasks</h5>
                    <p class="card-text">Remove tasks that are no longer needed from your task list.</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-4">
        <a asp-page="/Tasks/Index" class="btn btn-primary btn-lg">
            <i class="fas fa-arrow-right me-2"></i>Go to Tasks
        </a>
    </div>
</div>
